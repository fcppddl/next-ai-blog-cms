# 复制为 .env.docker 后填写（勿提交 .env.docker）
# 变量名与 .env.local 一致；数据库与 Chroma 连接由 docker-compose.yml 固定，无需写 DATABASE_URL / CHROMADB_HOST

NEXTAUTH_SECRET=请替换为至少32字符的随机字符串
NEXTAUTH_URL=http://localhost:3000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改为强密码

# 对话 API（DashScope 等）
# CHAT_API_KEY=
# CHAT_BASE_URL=
# CHAT_MODEL=

# 嵌入向量 API
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=1024

# RAG 重排序（可选）
# RAG_RERANK_API_KEY=
# RAG_RERANK_BASE_URL=
# RAG_RERANK_MODEL=
# RAG_RERANK_DISABLED=false
# RAG_RERANK_RECALL_K=10
# RAG_RERANK_TOP_K=3
