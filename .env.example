# 数据库配置
DATABASE_URL="file:./prisma/dev.db"

# NextAuth 配置
NEXTAUTH_SECRET=""
# 必须带协议 http:// 或 https://，且与浏览器访问一致。若只写 IP:端口，NextAuth 会按 https 解析，纯 HTTP 访问时 Cookie 无法使用、登录后会话异常
# 本地: http://localhost:3000；直连 Node 端口: http://x.x.x.x:3000；若仅 Nginx 80 对外则不要带 :3000
NEXTAUTH_URL="http://localhost:3000"
# 线上若走 Nginx/Caddy 等反向代理，设为 true，NextAuth 会用 X-Forwarded-Host 识别真实域名（否则可能错误使用上面的 NEXTAUTH_URL）
AUTH_TRUST_HOST="true"

# 管理员账户 (seed 时使用)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin"

# Ollama 配置 (用于向量生成)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# ChromaDB 配置 (用于向量存储)
CHROMADB_HOST="localhost"
CHROMADB_PORT="8000"

# AI 配置 (可选)
CHAT_API_KEY=""
CHAT_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# CHAT_MODEL="qwen3.5-plus"
CHAT_MODEL="qwen3.5-flash"

# Embedding 配置 (用于向量生成)
EMBEDDING_API_KEY=""
# Embedding 接口地址（默认https://dashscope.aliyuncs.com/compatible-mode/v1）
EMBEDDING_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# Embedding 模型
EMBEDDING_MODEL="text-embedding-v4"
# Embedding 维度（默认1024）
EMBEDDING_DIMENSIONS="1024"

# 重排序 API Key
RAG_RERANK_API_KEY=""
# 重排序接口地址（默认https://dashscope.aliyuncs.com/compatible-api/v1）
RAG_RERANK_BASE_URL="https://dashscope.aliyuncs.com/compatible-api/v1"
# 重排序模型（默认qwen3-rerank）
RAG_RERANK_MODEL="qwen3-rerank"
# 是否禁用重排序（默认不禁用）
RAG_RERANK_DISABLED=false
# 向量检索结果条数（默认10条）
RAG_RERANK_RECALL_K=10
# 重排序结果条数（最终返回结果条数，默认3条）
RAG_RERANK_TOP_K=3 